# ============================================================
# BARK BATTLE — Configuration d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# === Base de données PostgreSQL ===
POSTGRES_USER=bark
POSTGRES_PASSWORD=barkbattle2025_CHANGE_ME
POSTGRES_DB=bark_battle
DATABASE_URL=postgresql://bark:barkbattle2025_CHANGE_ME@localhost:5432/bark_battle

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT ===
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_IN_PRODUCTION

# === OAuth Google ===
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# === URLs ===
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001

# === Production (Vercel / Railway) ===
# FRONTEND_URL=https://barkbattle.com
# NEXT_PUBLIC_API_URL=https://api.barkbattle.com/api
# NEXT_PUBLIC_WS_URL=https://api.barkbattle.com
